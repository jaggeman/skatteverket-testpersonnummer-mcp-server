{
  "name": "skatteverket-testpersonnummer-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Skatteverket's official Swedish test personal numbers (testpersonnummer) dataset",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "skatteverket-testpersonnummer-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rimraf dist",
    "test": "tsx --test test/index.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "skatteverket",
    "personnummer",
    "testpersonnummer",
    "sweden",
    "swedish"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
